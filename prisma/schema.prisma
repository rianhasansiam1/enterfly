generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  password String? // nullable to support OAuth (e.g. Google) sign-in
  phone    String? // nullable: OAuth sign-ins don't collect this up-front
  city     String? // nullable: OAuth sign-ins don't collect this up-front
  image    String? // profile picture URL (e.g. Google avatar)
  role     Role    @default(USER)

  // Captured when the user accepts the Terms & Privacy at registration.
  // Null means the user has not (yet) accepted the latest terms.
  termsAcceptedAt DateTime?

  orders    Order[]
  cartItems CartItem[]
  wishlists Wishlist[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Category {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?
  image       String?
  status      CategoryStatus @default(ACTIVE)

  products        Product[]
  categoryBanners CategoryBanner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

model Product {
  id   String @id @default(cuid())
  name String

  description   String?
  price         Float
  discountPrice Float?
  stock         Int           @default(0)
  image         String?
  images        String[] // multiple product images
  rating        Float         @default(0)
  reviewCount   Int           @default(0)
  badge         String? // e.g. "Bestseller", "New", "Hot Deal", "Trending"
  status        ProductStatus @default(ACTIVE)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  cartItems  CartItem[]
  wishlists  Wishlist[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

model CartItem {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model Wishlist {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Order {
  id          String @id @default(cuid())
  orderNumber String @unique // human-readable receipt id, e.g. "ORD-260525-A1B2C3D4"

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items OrderItem[]

  subtotal       Float
  deliveryCharge Float @default(0)
  discountAmount Float @default(0)
  totalAmount    Float

  customerName    String
  customerPhone   String
  customerAddress String

  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod @default(CASH_ON_DELIVERY)
  paymentStatus PaymentStatus @default(UNPAID)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PAID
  UNPAID
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int
  price    Float // product price at order time

  createdAt DateTime @default(now())
}

model CarouselBanner {
  id          String  @id @default(cuid())
  image       String
  title       String // e.g. "25% OFF", "SPECIAL"
  subtitle    String // e.g. "VEGETABLES", "OFFER"
  description String // e.g. "Fresh vegetables delivered fast..."
  badge       String // e.g. "Weekend Special", "Flash Deal"
  bgFrom      String // gradient start class (e.g. "from-green-500")
  bgVia       String? // gradient middle class (e.g. "via-emerald-600")
  bgTo        String // gradient end class (e.g. "to-green-800")
  link        String?
  position    Int     @default(0)

  status CarouselBannerStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, position])
}

enum CarouselBannerStatus {
  ACTIVE
  INACTIVE
}

model CategoryBanner {
  id          String  @id @default(cuid())
  image       String
  label       String // e.g. "SALE", "MEGA DEAL"
  heading     String // e.g. "FLASH SALE", "TECH FEST"
  discount    String // e.g. "40%", "50%"
  description String
  link        String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  status CategoryBannerStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, status])
}

enum CategoryBannerStatus {
  ACTIVE
  INACTIVE
}

model TopBanner {
  id          String @id @default(cuid())
  icon        String // icon name (e.g. "Tag", "Gift", "Percent", "Sparkles")
  badge       String // e.g. "MEGA SALE", "FLASH DEAL"
  discount    String // e.g. "70% OFF", "Buy 2 Get 1"
  description String // e.g. "on all products"
  tag         String // e.g. "Limited Time Only", "Today Only"
  tagIcon     String // icon name (e.g. "Sparkles", "Zap", "TrendingUp")
  position    Int    @default(0)

  status TopBannerStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, position])
}

enum TopBannerStatus {
  ACTIVE
  INACTIVE
}

// Compact deal cards rendered in the horizontal carousel on the
// product-details page. Managed from the admin "Banners" page.
model DealBanner {
  id       String  @id @default(cuid())
  image    String
  title    String // e.g. "Up to 70% Off"
  subtitle String // e.g. "Black Friday"
  bgClass  String // tailwind bg utility, e.g. "bg-rose-500"
  link     String?
  position Int     @default(0)

  status DealBannerStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, position])
}

enum DealBannerStatus {
  ACTIVE
  INACTIVE
}

// Tall side-rail promo banners on the product-details page.
// Managed from the admin "Banners" page.
model PromoBanner {
  id       String  @id @default(cuid())
  image    String
  title    String // e.g. "Mega Sale"
  subtitle String // e.g. "Save Big Today"
  discount String // e.g. "UP TO 60% OFF"
  bgClass  String // tailwind bg utility, e.g. "bg-violet-700"
  link     String?
  position Int     @default(0)

  status PromoBannerStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, position])
}

enum PromoBannerStatus {
  ACTIVE
  INACTIVE
}

// Discount codes the customer can apply at checkout.
// Managed from the admin "Settings" page.
model PromoCode {
  id           String           @id @default(cuid())
  code         String           @unique // case-insensitive at the service layer
  description  String?
  discountType PromoDiscountType @default(FLAT)
  // FLAT: amount in currency units. PERCENT: 0..100 percentage of subtotal.
  value        Float
  minOrder     Float?           // minimum subtotal required to apply
  maxDiscount  Float?           // optional cap when discountType is PERCENT
  startsAt     DateTime?
  endsAt       DateTime?
  usageLimit   Int?             // total uses allowed across all customers
  usedCount    Int              @default(0)
  status       PromoCodeStatus  @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, code])
}

enum PromoDiscountType {
  FLAT
  PERCENT
}

enum PromoCodeStatus {
  ACTIVE
  INACTIVE
}

// Singleton row that stores cart-time settings the admin can tune
// without a deploy: tax rate, delivery charge, and free shipping
// threshold. Service ensures exactly one row exists.
model StoreSettings {
  id                    String @id @default(cuid())
  taxRate               Float  @default(0.05)   // 0..1, e.g. 0.05 = 5%
  standardShippingFee   Float  @default(120)
  freeShippingThreshold Float  @default(50000)  // BDT subtotal at which delivery is free
  expressShippingFee    Float  @default(250)
  currency              String @default("BDT")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Inbound messages submitted from the public /contact form.
// Captured without requiring a logged-in user; the admin can review,
// mark as read, archive, or delete from the admin "Messages" page.
model ContactMessage {
  id      String @id @default(cuid())
  name    String
  email   String
  phone   String?
  subject String
  message String

  status ContactMessageStatus @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
}

enum ContactMessageStatus {
  NEW
  READ
  ARCHIVED
}
