generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  password String?
  phone    String
  role     Role    @default(USER)

  orders    Order[]
  cartItems CartItem[]
  wishlists Wishlist[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Category {
  id    String  @id @default(cuid())
  name  String
  image String?

  products        Product[]
  categoryBanners CategoryBanner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id   String @id @default(cuid())
  name String

  description   String?
  price         Float
  discountPrice Float?
  stock         Int           @default(0)
  image         String?
  images        String[] // multiple product images
  status        ProductStatus @default(ACTIVE)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  cartItems  CartItem[]
  wishlists  Wishlist[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

model CartItem {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model Wishlist {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Order {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items OrderItem[]

  totalAmount    Float
  deliveryCharge Float @default(0)
  discountAmount Float @default(0)

  customerName    String
  customerPhone   String
  customerAddress String

  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod @default(CASH_ON_DELIVERY)
  paymentStatus PaymentStatus @default(UNPAID)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PAID
  UNPAID
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int
  price    Float // product price at order time

  createdAt DateTime @default(now())
}

model CarouselBanner {
  id          String  @id @default(cuid())
  image       String
  title       String // e.g. "25% OFF", "SPECIAL"
  subtitle    String // e.g. "VEGETABLES", "OFFER"
  description String // e.g. "Fresh vegetables delivered fast..."
  badge       String // e.g. "Weekend Special", "Flash Deal"
  bgFrom      String // gradient start class (e.g. "from-green-500")
  bgVia       String? // gradient middle class (e.g. "via-emerald-600")
  bgTo        String // gradient end class (e.g. "to-green-800")
  link        String?
  position    Int     @default(0)

  status CarouselBannerStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, position])
}

enum CarouselBannerStatus {
  ACTIVE
  INACTIVE
}

model CategoryBanner {
  id          String  @id @default(cuid())
  image       String
  label       String // e.g. "SALE", "MEGA DEAL"
  heading     String // e.g. "FLASH SALE", "TECH FEST"
  discount    String // e.g. "40%", "50%"
  description String
  link        String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  status CategoryBannerStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, status])
}

enum CategoryBannerStatus {
  ACTIVE
  INACTIVE
}

model TopBanner {
  id          String @id @default(cuid())
  icon        String // icon name (e.g. "Tag", "Gift", "Percent", "Sparkles")
  badge       String // e.g. "MEGA SALE", "FLASH DEAL"
  discount    String // e.g. "70% OFF", "Buy 2 Get 1"
  description String // e.g. "on all products"
  tag         String // e.g. "Limited Time Only", "Today Only"
  tagIcon     String // icon name (e.g. "Sparkles", "Zap", "TrendingUp")
  position    Int    @default(0)

  status TopBannerStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, position])
}

enum TopBannerStatus {
  ACTIVE
  INACTIVE
}
