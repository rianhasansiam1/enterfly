generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}







 //Users & auth
model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  password String? 
  phone    String?
  city     String?
  image    String? 
  role     Role    @default(USER)

  
  provider AuthProvider @default(CREDENTIAL)
  termsAcceptedAt DateTime?

  orders          Order[]
  cartItems       CartItem[]
  wishlists       Wishlist[]
  addresses       Address[]
  promoCodeUsages PromoCodeUsage[]
  reviews         Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

enum AuthProvider {
  CREDENTIAL
  GOOGLE
}






 // Catalog
model Category {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?
  image       String?
  status      CategoryStatus @default(ACTIVE)

  products Product[]
  banners  Banner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  status      ProductStatus @default(ACTIVE)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  variants ProductVariant[]
  images   ProductImage[]

  cartItems  CartItem[]
  wishlists  Wishlist[]
  orderItems OrderItem[]
  reviews    Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, status])
  @@index([status, createdAt])
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku       String   @unique
  color     String?
  size      String?
  price     Decimal  @db.Decimal(10, 2)
  salePrice Decimal? @db.Decimal(10, 2)
  stock     Int      @default(0)

  cartItems     CartItem[]
  orderItems    OrderItem[]
  inventoryLogs InventoryLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([stock])
  @@index([price])
  @@index([salePrice])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  url      String
  alt      String?
  position Int     @default(0)

  createdAt DateTime @default(now())

  @@index([productId])
}

/**
 * --------------------------------------------------------------------------
 */
/**
 * Cart & wishlist
 */
/**
 * --------------------------------------------------------------------------
 */

// One row per (user, variant). `variantId` identifies the exact
// purchasable item (e.g. "Black / Large"); `productId` is kept for
// easy product-level querying.
model CartItem {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  quantity Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, variantId])
  @@index([userId])
  @@index([productId])
  @@index([variantId])
}

model Wishlist {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

/**
 * --------------------------------------------------------------------------
 */
/**
 * Orders
 */
/**
 * --------------------------------------------------------------------------
 */

// Checkout is authenticated-only: every order belongs to a real user.
// onDelete: Restrict protects order history from accidental user deletes.
model Order {
  id          String @id @default(cuid())
  orderNumber String @unique // e.g. "ORD-260525-A1B2C3D4"

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  items OrderItem[]

  subtotal       Decimal @db.Decimal(10, 2)
  deliveryCharge Decimal @default(0) @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  taxAmount      Decimal @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal @db.Decimal(10, 2)

  customerName       String
  customerPhone      String
  customerAddress    String
  customerEmail      String? // optional override for the receipt email
  customerCity       String? // city / district
  customerArea       String? // area / thana, copied from the saved Address
  customerPostalCode String? // ZIP / postal code
  customerNote       String? // optional shipping/delivery note from the customer

  promoCode String? // snapshot of the code applied at order time

  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod @default(CASH_ON_DELIVERY)
  paymentStatus PaymentStatus @default(UNPAID)

  payments        PaymentTransaction[]
  promoCodeUsages PromoCodeUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  ONLINE
}

enum PaymentStatus {
  PAID
  UNPAID
}

// One line per ordered variant. `productId`/`variantId` are nullable and
// SET NULL on delete so order history survives product/variant removal.
// The snapshot fields preserve exactly what was purchased.
model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  // Snapshot of the purchased item at order time.
  productName  String
  productImage String?
  sku          String?
  color        String?
  size         String?
  quantity     Int
  unitPrice    Decimal @db.Decimal(10, 2)
  totalPrice   Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

/**
 * --------------------------------------------------------------------------
 */
/**
 * Reviews
 */
/**
 * --------------------------------------------------------------------------
 */

// Product reviews. Two origins (see `source`):
//   - CUSTOMER: written by a logged-in user who received the product
//     (the create path enforces a DELIVERED order for that product), so
//     `userId` is set and `verified` is true.
//   - ADMIN: seeded by an admin for a product; `userId` is null and the
//     display name is captured in `authorName`.
// `userId` is SET NULL on user delete so the review (and its rating)
// survives account removal. `authorName` snapshots the display name so
// the UI never needs to join back to User.
model Review {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  authorName String // snapshot of the reviewer's display name
  rating     Int // 1..5
  title      String?
  comment    String?

  source   ReviewSource @default(CUSTOMER)
  verified Boolean      @default(false) // true when tied to a delivered order

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One review per user per product. Admin-seeded rows keep userId null;
  // Postgres treats NULLs as distinct so many admin rows per product are
  // allowed, while a real user is capped at one review per product.
  @@unique([userId, productId])
  @@index([productId, createdAt])
  @@index([rating])
}

enum ReviewSource {
  CUSTOMER
  ADMIN
}

/**
 * --------------------------------------------------------------------------
 */
/**
 * Testimonials
 */
/**
 * --------------------------------------------------------------------------
 */

// Admin-managed shopper testimonials shown in the "Loved by shoppers"
// section on the About page. Independent from product `Review`s: these
// are curated marketing quotes, not tied to a user or product. The
// storefront reads only ACTIVE rows, ordered by `position` then newest.
model Testimonial {
  id       String            @id @default(cuid())
  name     String
  location String?
  image    String? // hosted avatar URL (optional)
  rating   Int               @default(5) // 1..5
  text     String
  position Int               @default(0)
  status   TestimonialStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, position])
}

enum TestimonialStatus {
  ACTIVE
  INACTIVE
}

/**
 * --------------------------------------------------------------------------
 */
/**
 * Promo codes
 */
/**
 * --------------------------------------------------------------------------
 */

// Discount codes applied at checkout. `code` is stored uppercase by the
// service layer and is unique. For true case-insensitive uniqueness add a
// manual migration: CREATE UNIQUE INDEX "PromoCode_code_lower_key"
//   ON "PromoCode" (LOWER(code));
model PromoCode {
  id           String            @id @default(cuid())
  code         String            @unique
  description  String?
  discountType PromoDiscountType @default(FLAT)
  // FLAT: amount in currency units. PERCENT: 0..100 percentage of subtotal.
  value        Decimal           @db.Decimal(10, 2)
  minOrder     Decimal?          @db.Decimal(10, 2)
  maxDiscount  Decimal?          @db.Decimal(10, 2)
  startsAt     DateTime?
  endsAt       DateTime?
  usageLimit   Int?
  usedCount    Int               @default(0)
  status       PromoCodeStatus   @default(ACTIVE)

  usages PromoCodeUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, code])
}

enum PromoDiscountType {
  FLAT
  PERCENT
}

enum PromoCodeStatus {
  ACTIVE
  INACTIVE
}

// Records each application of a promo code so usage can be audited.
// Restrict on order/promoCode keeps audit data from being wiped.
model PromoCodeUsage {
  id          String    @id @default(cuid())
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Restrict)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Restrict)

  usedAt DateTime @default(now())

  @@unique([promoCodeId, orderId])
  @@index([promoCodeId])
  @@index([userId])
  @@index([orderId])
}

/**
 * --------------------------------------------------------------------------
 */
/**
 * Store settings
 */
/**
 * --------------------------------------------------------------------------
 */

// Singleton row holding cart-time settings the admin can tune.
model StoreSettings {
  id                    String  @id @default(cuid())
  taxRate               Decimal @default(0.05) @db.Decimal(5, 4) // 0..1, e.g. 0.05 = 5%
  standardShippingFee   Decimal @default(120) @db.Decimal(10, 2)
  freeShippingThreshold Decimal @default(50000) @db.Decimal(10, 2) // BDT subtotal at which delivery is free
  expressShippingFee    Decimal @default(250) @db.Decimal(10, 2)
  currency              String  @default("BDT")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * --------------------------------------------------------------------------
 */
/**
 * Contact / addresses / payments / inventory
 */
/**
 * --------------------------------------------------------------------------
 */

// Inbound messages submitted from the public /contact form.
model ContactMessage {
  id      String  @id @default(cuid())
  name    String
  email   String
  phone   String?
  subject String
  message String

  status ContactMessageStatus @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
}

enum ContactMessageStatus {
  NEW
  READ
  ARCHIVED
}

// Saved shipping addresses for a user. Copied into the Order's customer*
// fields at checkout so the order snapshot survives address edits/deletes.
model Address {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName   String
  phone      String
  city       String
  area       String?
  address    String
  postalCode String?
  isDefault  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// One row per payment attempt against an order.
model PaymentTransaction {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  provider      String // SSLCommerz, Stripe, bKash, Nagad
  transactionId String?
  amount        Decimal                  @db.Decimal(10, 2)
  currency      String                   @default("BDT")
  status        PaymentTransactionStatus @default(PENDING)
  rawResponse   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([transactionId])
}

enum PaymentTransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
}

// Append-only ledger of stock movements, tracked per variant.
model InventoryLog {
  id        String         @id @default(cuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  type     InventoryLogType
  quantity Int
  note     String?

  createdAt DateTime @default(now())

  @@index([variantId])
}

enum InventoryLogType {
  STOCK_IN
  STOCK_OUT
  ORDER_PLACED
  ORDER_CANCELLED
  RETURNED
  MANUAL_ADJUSTMENT
}

/**
 * --------------------------------------------------------------------------
 */
/**
 * Banners (unified)
 */
/**
 * --------------------------------------------------------------------------
 */

// Single admin-managed banner model. `type` selects the render location;
// `metadata` holds type-specific extras (gradients, icons, badges, etc.)
// so the table stays lean instead of carrying dozens of nullable columns.
model Banner {
  id          String       @id @default(cuid())
  type        BannerType
  title       String?
  subtitle    String?
  description String?
  image       String?
  link        String?
  position    Int          @default(0)
  status      BannerStatus @default(ACTIVE)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Type-specific fields, e.g. icon, badge, discount, tag, tagIcon,
  // bgClass, bgFrom, bgVia, bgTo, label, heading.
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status, position])
  @@index([categoryId, status])
}

enum BannerType {
  CAROUSEL
  CATEGORY
  TOP
  DEAL
  PROMO
}

enum BannerStatus {
  ACTIVE
  INACTIVE
}
